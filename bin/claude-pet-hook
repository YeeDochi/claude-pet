#!/usr/bin/env python3
"""claude-pet-hook — forwards a Claude Code hook event to the running pet.

Registered in ~/.claude/settings.json for each hook event. Claude Code invokes
it with the event name as argv[1] and the hook payload as JSON on stdin. It
sends {"event", "session"} to the pet's unix socket and exits 0 immediately.

Must never block or fail Claude: any error is swallowed and exit is always 0.
"""
import sys
import os
import json
import socket

SOCK = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "claude-pet.sock")


def main():
    raw = ""
    try:
        if not sys.stdin.isatty():
            raw = sys.stdin.read()
    except Exception:
        pass
    data = {}
    try:
        data = json.loads(raw) if raw.strip() else {}
    except Exception:
        data = {}

    event = (sys.argv[1] if len(sys.argv) > 1 else "") or data.get("hook_event_name", "")
    session = data.get("session_id") or "default"
    msg = (json.dumps({"event": event, "session": session}) + "\n").encode()

    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(0.3)
        s.connect(SOCK)
        s.sendall(msg)
        s.close()
    except Exception:
        pass  # pet not running — ignore silently


if __name__ == "__main__":
    main()
    sys.exit(0)   # hooks must always succeed
